# ~/.config/shell/exports.zsh

# Locale
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Editors
export EDITOR="nvim"
export VISUAL="nvim"

# Pager
export PAGER="less"

# Less options
export LESS='-R'

# History
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=10000
export SAVEHIST=10000

# User bin
export PATH="$HOME/bin:$PATH"

# man pahge
export MANPAGER="nvim +Man!"
